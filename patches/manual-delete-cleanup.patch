diff --git a/src/util/threadkeeper-cleanup.js b/src/util/threadkeeper-cleanup.js
new file mode 100644
--- /dev/null
+++ b/src/util/threadkeeper-cleanup.js
@@ -0,0 +1,88 @@
+import fs from 'node:fs';
+import path from 'node:path';
+
+import { SETTINGS_FILE } from '../constants.js';
+
+const MODULE_NAME = 'threadkeeper';
+const CHAT_FILE_EXTENSION = '.jsonl';
+
+function walkFiles(rootDirectory, predicate, results = []) {
+    if (!fs.existsSync(rootDirectory)) {
+        return results;
+    }
+
+    for (const entry of fs.readdirSync(rootDirectory, { withFileTypes: true })) {
+        const fullPath = path.join(rootDirectory, entry.name);
+        if (entry.isDirectory()) {
+            walkFiles(fullPath, predicate, results);
+            continue;
+        }
+
+        if (predicate(fullPath, entry)) {
+            results.push(fullPath);
+        }
+    }
+
+    return results;
+}
+
+function rewriteChatHeaderWithoutThreadKeeper(filePath) {
+    const content = fs.readFileSync(filePath, 'utf8');
+    const newlineMatch = content.match(/\r?\n/);
+    const newline = newlineMatch?.[0] ?? '';
+    const splitIndex = newline ? content.indexOf(newline) : -1;
+    const firstLine = splitIndex === -1 ? content : content.slice(0, splitIndex);
+
+    if (!firstLine.trim()) {
+        return false;
+    }
+
+    let header;
+    try {
+        header = JSON.parse(firstLine);
+    } catch {
+        return false;
+    }
+
+    if (!header?.chat_metadata || !Object.hasOwn(header.chat_metadata, MODULE_NAME)) {
+        return false;
+    }
+
+    delete header.chat_metadata[MODULE_NAME];
+    const remainder = splitIndex === -1 ? '' : content.slice(splitIndex + newline.length);
+    const nextContent = remainder ? `${JSON.stringify(header)}${newline}${remainder}` : JSON.stringify(header);
+    fs.writeFileSync(filePath, nextContent, 'utf8');
+    return true;
+}
+
+function cleanupSettings(userDirectories) {
+    const settingsPath = path.join(userDirectories.root, SETTINGS_FILE);
+
+    if (!fs.existsSync(settingsPath)) {
+        return false;
+    }
+
+    let settings;
+    try {
+        settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8'));
+    } catch {
+        return false;
+    }
+
+    if (!settings?.extension_settings || !Object.hasOwn(settings.extension_settings, MODULE_NAME)) {
+        return false;
+    }
+
+    delete settings.extension_settings[MODULE_NAME];
+    fs.writeFileSync(settingsPath, JSON.stringify(settings, null, 4), 'utf8');
+    return true;
+}
+
+export function removeThreadKeeperPersistedData(userDirectories) {
+    const chatFiles = [
+        ...walkFiles(userDirectories.chats, filePath => path.extname(filePath).toLowerCase() === CHAT_FILE_EXTENSION),
+        ...walkFiles(userDirectories.groupChats, filePath => path.extname(filePath).toLowerCase() === CHAT_FILE_EXTENSION),
+    ];
+
+    let cleanedChats = 0;
+    for (const filePath of chatFiles) {
+        if (rewriteChatHeaderWithoutThreadKeeper(filePath)) {
+            cleanedChats++;
+        }
+    }
+
+    return {
+        cleanedSettings: cleanupSettings(userDirectories),
+        cleanedChats,
+    };
+}
